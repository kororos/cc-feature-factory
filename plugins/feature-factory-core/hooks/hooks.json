{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/pre-commit.sh\" 1>&2 || exit 2",
            "statusMessage": "Scanning staged files for secrets..."
          }
        ]
      }
    ]
  }
}
